generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TruckType {
  MEDIUM
  HEAVY
  TRAILER
}

enum GoodsType {
  CONSTRUCTION
  MACHINERY
  STEEL
  CEMENT
  AUTOMOBILE
  CONTAINER
  AGRICULTURE
  OTHER
}

enum BookingStatus {
  PENDING
  AWAITING_OWNER
  CONFIRMED
  DECLINED
  CANCELLED
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  passwordHash  String?
  name          String?
  phone         String?   @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  bookings      Booking[]
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model Owner {
  id              String     @id @default(cuid())
  name            String
  company         String
  phone           String
  email           String     @unique
  passwordHash    String?
  baseCity        String
  fleet           Int
  rating          Float      @default(4.5)
  specializations String[]
  truckTypes      TruckType[]
  createdAt       DateTime   @default(now())

  bookings        Booking[]
}

model Booking {
  id            String         @id @default(cuid())
  pickupCity    String
  dropCity      String
  goodsType     GoodsType
  weightTons    Float
  distanceKm    Float
  truckType     TruckType
  fareEstimate  Float
  bookingDate   DateTime
  status        BookingStatus  @default(PENDING)
  customerName  String?
  customerEmail String?
  customerPhone String?
  notes         String?
  createdAt     DateTime       @default(now())

  ownerId       String?
  owner         Owner?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([truckType])
  @@index([customerEmail])
  @@index([ownerId])
  @@index([userId])
}
